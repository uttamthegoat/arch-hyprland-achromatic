# --- Window Layout ---
width = 35%
height = 27%
# Added border radius for a rounded look
corner-radius = 12
border-width = 1
outline-width = 0
padding-top = 15
padding-left = 15

# --- Colors (Black & White) ---
background-color = #000000
border-color = #919090

# Text Colors
text-color = #cccccc
prompt-color = #cccccc
input-color = #cccccc

# Selection Colors
selection-color = #000000
selection-background = #c2c0c0
# Rounded padding for the selection highlight to match the menu
selection-background-corner-radius = 5
selection-background-padding = 4

# --- Font ---
font = /usr/share/fonts/TTF/DejaVuSans.ttf
# Reduced font size for a more minimal feel
font-size = 11

# --- Behavior ---
hint-font = false
num-results = 6
result-spacing = 12
prompt-text = "Bhag BSDK: "


drun-launch = true
